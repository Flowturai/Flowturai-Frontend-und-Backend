{
  "productName": "Flowturai",
  "version": "2.0.0",
  "identifier": "de.flowturai.dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Flowturai Dashboard",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../admin/**/*"],
    "publisher": "Jeremy Jung",
    "copyright": "© 2026 Flowturai",
    "category": "Business",
    "shortDescription": "Flowturai CRM & Controlling",
    "longDescription": "Internes Dashboard für Flowturai – Kundenverwaltung, Rechnungen, Analytics.",
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": { "type": "embedBootstrapper" }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null
    },
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://DEINE_DOMAIN/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
