# ============================================================
# FLOWTURAI – Umgebungsvariablen v2 (Hetzner / Docker)
# Datei kopieren → .env  – dann alle Werte ausfüllen
# ============================================================

# ── Umgebung ────────────────────────────────────────────────
# "production" oder "staging"
ENVIRONMENT=production

# ── Datenbank ───────────────────────────────────────────────
# Wird von Docker Compose automatisch zusammengebaut
DB_PASSWORD=sicheres_passwort_hier_eingeben
# Für Staging (separates Passwort!)
DB_PASSWORD_STAGING=staging_passwort_hier

# ── KI (Claude API) ─────────────────────────────────────────
# https://console.anthropic.com → API Keys → Create Key
# WICHTIG: Schreib von Anthropic (DPA) für DSGVO unterschreiben!
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── E-Mail (IONOS) ──────────────────────────────────────────
# Deine IONOS-E-Mail-Adresse (z.B. hallo@flowturai.de)
IONOS_EMAIL=hallo@flowturai.de
# IONOS-E-Mail-Passwort (oder App-Passwort)
IONOS_PASSWORD=dein_ionos_passwort
IONOS_SMTP_HOST=smtp.ionos.de
IONOS_SMTP_PORT=587

# ── Admin ───────────────────────────────────────────────────
# Dein Dashboard-Passwort – wähle etwas Sicheres (min. 16 Zeichen)
ADMIN_SECRET_KEY=flowturai_admin_sicheres_passwort_2026
# Separater Key für Staging
ADMIN_SECRET_KEY_STAGING=flowturai_staging_key_2026

# Deine E-Mail für interne Benachrichtigungen
ADMIN_EMAIL=jungjeremy28@gmail.com

# Deine Domain (ohne https://)
DOMAIN=flowturai.de

# ── Rechnungsdaten ──────────────────────────────────────────
BUSINESS_ADDRESS=Musterstraße 1, 12345 Musterstadt
BANK_HOLDER=Jeremy Jung
BANK_IBAN=DE00 0000 0000 0000 0000 00
BANK_BIC=XXXXXXXX
